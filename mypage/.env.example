# Telegram
BOT_TOKEN=put-your-token-here

# Local AI services (optional; fallback kicks in if missing)
OLLAMA_URL=http://localhost:11434
COMFYUI_URL=http://localhost:8188

# Payments
LAVA_API_KEY=
LAVA_PRODUCT_ID=
CRYPTOCLOUD_API_KEY=
CRYPTOCLOUD_SHOP_ID=

# Storage
DB_PATH=./mypage.db

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=

# --- Order parser (optional) ---
# Create an app at https://my.telegram.org to get API_ID and API_HASH.
# Then run `python -m parsers.login` once locally to generate the session string.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
# Comma-separated list of public channel @handles to watch for orders.
PARSER_CHANNELS=

# --- YouTube monitor (optional) ---
# Comma-separated @handles or URLs; defaults to the 4 brand channels below.
YOUTUBE_CHANNELS=@andxstars,@andxsound,@aimonax,@sferastars
# How often (minutes) to poll the RSS feeds — min 1, default 30.
YOUTUBE_POLL_MINUTES=30
